# API Keys - 이 파일을 secrets.yaml로 복사 후 실제 값 입력
# !! secrets.yaml은 .gitignore에 포함되어야 합니다 !!

hyperliquid:
  # https://app.hyperliquid.xyz/API 에서 생성
  wallet_address: "0x..."
  private_key: "0x..."

kiwoom:
  # 키움증권 OpenAPI-W 계정 정보 (사용 안함, KIS로 전환)
  account_number: ""
  account_password: ""

kis:
  # 한국투자증권 KIS Developers (https://apiportal.koreainvestment.com)
  app_key: ""
  app_secret: ""
  account_number: ""          # 계좌번호 (8자리-2자리, 예: "50123456-01")

telegram:
  bot_token: ""
  chat_id: ""
